# ==============================================================================
# Agentic Decision Intelligence Platform - Environment Configuration Template
# Copy this file to '.env' and fill in your details.
# ==============================================================================

# Core AI Service Configuration
# Your OpenRouter API Key (required for Gemma 3 27B model calls)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Database & Memory Configuration (Optional: defaults will be absolute paths under BASE_DIR)
# DATABASE_URL=sqlite:///backend/data/platform.db
# CHROMA_PATH=backend/data/chroma

# Application Infrastructure Config
LOG_LEVEL=INFO
ENVIRONMENT=development

# Observability Configuration (Optional: LangSmith tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agentic-decision-platform
LANGSMITH_API_KEY=your-langsmith-api-key-here

# Guardrails & Features
ENABLE_CONTEXT_SYNTHESIS=false
ENABLE_PII_REDACTION=true
ENABLE_PROMPT_GUARD=true
ENABLE_HEURISTIC_FALLBACK=true
ENABLE_LEARNING_FILTER=true
